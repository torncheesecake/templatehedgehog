# -------------------------------
# Template branding and metadata
# -------------------------------
NEXT_PUBLIC_SITE_URL=https://templatehedgehog.co.uk
# Optional canonical app URL override used by checkout/success links.
NEXT_PUBLIC_APP_URL=https://templatehedgehog.co.uk
NEXT_PUBLIC_SITE_DOMAIN=templatehedgehog.co.uk
NEXT_PUBLIC_BRAND_NAME=Template Hedgehog
NEXT_PUBLIC_PRODUCT_NAME=Template Hedgehog Pro
NEXT_PUBLIC_SUPPORT_EMAIL=support@templatehedgehog.co.uk
NEXT_PUBLIC_CONTACT_EMAIL=hello@templatehedgehog.co.uk
NEXT_PUBLIC_COMPANY_LEGAL_NAME=Artifexa
NEXT_PUBLIC_COMPANY_ADDRESS=Artifexa, United Kingdom
NEXT_PUBLIC_PRODUCT_OWNER_NAME=Artifexa
NEXT_PUBLIC_PRODUCT_OWNER_URL=

# -------------------------------
# Checkout and webhooks (Stripe)
# Required for /api/checkout, /success, /api/webhooks/stripe, and /api/download
# -------------------------------
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# -------------------------------
# Download token protection
# Required for signed /api/downloads/[token] links
# -------------------------------
DOWNLOAD_TOKEN_SECRET=replace-with-a-long-random-secret
DOWNLOAD_TOKEN_REPLAY_STORE=redis
# Single-process fallback only. Keep false when Redis is available.
DOWNLOAD_TOKEN_MEMORY_REPLAY_ENABLED=false

# -------------------------------
# Shared persistence (multi-instance safe)
# Required in production for:
# - waitlist storage
# - waitlist rate limiting
# - download token replay protection
# -------------------------------
REDIS_URL=redis://:password@localhost:6379/0
SHARED_STORE_PREFIX=template-hedgehog

# -------------------------------
# Download storage
# Production should use provider mode (filesystem mode is blocked in production)
# -------------------------------
DOWNLOAD_STORAGE_MODE=provider
# Single-server fallback only. Keep false unless the private zip is outside
# the nginx/web root and downloads are gated through the app.
DOWNLOAD_FILESYSTEM_ENABLED=false
DOWNLOAD_PROVIDER=s3
DOWNLOAD_PROVIDER_BUCKET=your-download-bucket
DOWNLOAD_PROVIDER_REGION=eu-west-2
DOWNLOAD_PROVIDER_ACCESS_KEY_ID=replace-me
DOWNLOAD_PROVIDER_SECRET_ACCESS_KEY=replace-me
DOWNLOAD_PROVIDER_PREFIX=downloads
DOWNLOAD_PROVIDER_ENDPOINT=
DOWNLOAD_PROVIDER_FORCE_PATH_STYLE=false
DOWNLOAD_PROVIDER_SESSION_TOKEN=

# -------------------------------
# Waitlist storage
# "memory" is for local development only. "redis" is recommended for multi-instance
# production. "file" is supported for a single-server VPS fallback.
# -------------------------------
WAITLIST_STORAGE_MODE=memory
WAITLIST_FILE_PATH=.data/waitlist.jsonl
RATE_LIMIT_STORE_MODE=memory

# -------------------------------
# Development helpers
# -------------------------------
NEXT_PUBLIC_DEV_OWNED_PACK_IDS=pack-1
MARKETING_EMAIL_TEMPLATES_ROOT=./private/marketing-email-templates
PREVIEW_SLUGS=
